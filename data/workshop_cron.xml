<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Regla de negocio: una orden en taller que lleva más de 24 h en pausa
         (se priorizó otra de la cola y nadie la retomó) se devuelve a la cola
         priorizada, arriba, como la siguiente a retomar. -->
    <record id="ir_cron_workshop_auto_park" model="ir.cron">
        <field name="name">Taller: devolver a la cola órdenes pausadas &gt; 24 h</field>
        <field name="model_id" ref="model_workshop_order"/>
        <field name="state">code</field>
        <field name="code">model._cron_auto_park_paused_orders()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
