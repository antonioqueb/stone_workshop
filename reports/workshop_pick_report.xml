<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_workshop_pick" model="ir.actions.report">
        <field name="name">Orden de recolección de taller</field>
        <field name="model">workshop.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">stone_workshop.report_workshop_pick</field>
        <field name="report_file">stone_workshop.report_workshop_pick</field>
        <field name="binding_model_id" ref="model_workshop_order"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Recoleccion-%s' % (object.name or '').replace('/', '-')</field>
    </record>

    <template id="report_workshop_pick">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">

                    <t t-set="lines" t-value="o.input_line_ids.filtered(lambda l: l.state != 'cancelled')"/>
                    <t t-set="line_count" t-value="len(lines)"/>

                    <t t-set="priority_label"
                       t-value="'URGENTE' if o.priority == '2' else 'ALTA' if o.priority == '1' else 'Normal'"/>

                    <div class="page" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 10px; color: #222; line-height: 1.25;">
                        <t t-call="stock_lot_dimensions.som_report_style"/>

                        <!-- ================= ENCABEZADO ================= -->
                        <div class="row border-bottom pb-2 mb-2" style="border-color: #2f2f2f !important; align-items: center;">
                            <div class="col-8">
                                <h4 class="som-doc-title mb-0">
                                    Orden
                                    <span t-field="o.name" style="margin-left: 10px; color: #555;"/>
                                </h4>
                            </div>
                            <div class="col-4 text-end">
                                <div class="som-doc-subtitle" style="margin: 4px 0 0 0;">
                                    Impreso: <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                                </div>
                            </div>
                        </div>

                        <!-- ================= ALERTA URGENTE ================= -->
                        <div class="row mb-3" t-if="o.priority == '2'">
                            <div class="col-12">
                                <div style="border: 4px solid #b00020; background-color: #fff5f5; padding: 8px; width: 100%; box-sizing: border-box;">
                                    <div style="color: #b00020; font-weight: 900; font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px;">
                                        ⚠️ ORDEN URGENTE — PRIORIZAR RECOLECCIÓN
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ================= INFORMACIÓN GENERAL ================= -->
                        <div id="informations" style="margin-bottom: 12px; font-size: 10px;">
                            <table style="font-size: 9px; width: 100%; border-collapse: collapse; border: 1px solid #d8d8d8 !important; table-layout: fixed;">
                                <colgroup>
                                    <col style="width: 34%;"/>
                                    <col style="width: 34%;"/>
                                    <col style="width: 32%;"/>
                                </colgroup>

                                <thead>
                                    <tr>
                                        <th class="som-section-title">Proceso / Operación</th>
                                        <th class="som-section-title">Ruta de recolección</th>
                                        <th class="som-section-title">Estado del Documento</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <tr>
                                        <!-- PROCESO / OPERACIÓN -->
                                        <td style="vertical-align: top; padding: 0; border: 1px solid #d8d8d8 !important;">
                                            <div class="som-info-row">
                                                <div class="som-info-label">Proceso</div>
                                                <div class="som-info-value"><span t-field="o.process_id"/></div>
                                            </div>
                                            <div class="som-info-row">
                                                <div class="som-info-label">Modo operativo</div>
                                                <div class="som-info-value"><span t-field="o.operation_mode"/></div>
                                            </div>
                                            <div class="som-info-row">
                                                <div class="som-info-label">Responsable</div>
                                                <div class="som-info-value"><span t-field="o.responsible_id"/></div>
                                            </div>
                                        </td>

                                        <!-- RUTA DE RECOLECCIÓN -->
                                        <td style="vertical-align: top; padding: 0; border: 1px solid #d8d8d8 !important;">
                                            <div class="som-info-row">
                                                <div class="som-info-label">Origen</div>
                                                <div class="som-info-value"><span t-field="o.location_src_id"/></div>
                                            </div>
                                            <div class="som-info-row">
                                                <div class="som-info-label">Taller (destino)</div>
                                                <div class="som-info-value"><span t-field="o.location_workshop_id"/></div>
                                            </div>
                                        </td>

                                        <!-- ESTADO DEL DOCUMENTO -->
                                        <td style="vertical-align: top; padding: 0; border: 1px solid #d8d8d8 !important;">
                                            <div class="som-info-row">
                                                <div class="som-info-label" style="width: 45%;">Fecha planeada</div>
                                                <div class="som-info-value" style="text-align: right; font-variant-numeric: tabular-nums;">
                                                    <span t-field="o.date_planned" t-options='{"widget": "date"}'/>
                                                </div>
                                            </div>
                                            <div class="som-info-row">
                                                <div class="som-info-label" style="width: 45%;">Prioridad</div>
                                                <div class="som-info-value" style="text-align: right; font-weight: 700;">
                                                    <span t-if="o.priority == '2'" style="color: #b00020;">URGENTE</span>
                                                    <span t-elif="o.priority == '1'" style="color: #b8860b;">ALTA</span>
                                                    <span t-else="" style="color: #222;">Normal</span>
                                                </div>
                                            </div>
                                            <div class="som-info-row">
                                                <div class="som-info-label" style="width: 45%;">Estado</div>
                                                <div class="som-info-value" style="text-align: right;">
                                                    <span t-field="o.state"/>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- ================= ENCABEZADO DE SECCIÓN ================= -->
                        <div class="som-section-title som-avoid-break" style="margin-top: 14px; margin-bottom: 6px;">
                            Placas a recolectar
                        </div>

                        <!-- ================= TABLA DE PLACAS ================= -->
                        <!-- Agrupada por PRODUCTO (mismo estilo que el reporte de
                             detalle de la orden de venta): el producto aparece UNA
                             vez como fila agrupadora y debajo sus lotes con bloque,
                             espesor, largo, alto, ubicación y m². -->
                        <t t-set="pick_products" t-value="lines.mapped('product_id')"/>
                        <t t-set="global_seq" t-value="1"/>
                        <table class="som-table">
                            <thead>
                                <tr>
                                    <th class="text-center" style="width: 4%;">#</th>
                                    <th style="width: 15%;">Lote / Placa</th>
                                    <th style="width: 12%;">Bloque</th>
                                    <th class="text-center" style="width: 8%;">Espesor</th>
                                    <th class="text-center" style="width: 8%;">Largo</th>
                                    <th class="text-center" style="width: 8%;">Alto</th>
                                    <th style="width: 27%;">Ubicación origen</th>
                                    <th class="text-end" style="width: 8%;">m²</th>
                                    <th class="text-center" style="width: 5%;">✔</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="pick_products" t-as="pick_product">
                                    <t t-set="prod_lines" t-value="lines.filtered(lambda l: l.product_id == pick_product)"/>

                                    <!-- FILA DE PRODUCTO AGRUPADOR -->
                                    <tr>
                                        <td colspan="9" class="som-section-title">
                                            <span t-esc="pick_product.display_name"/>
                                            <span class="som-small som-muted" style="font-weight: 400; text-transform: none;">
                                                · <t t-esc="len(prod_lines)"/> placa<t t-if="len(prod_lines) != 1">s</t>
                                                · <t t-esc="'%.4f' % sum(prod_lines.mapped('area_sqm'))"/> m²
                                            </span>
                                        </td>
                                    </tr>

                                    <t t-foreach="prod_lines" t-as="line">
                                        <t t-set="lot" t-value="line.lot_id"/>
                                        <t t-set="loc_full" t-value="line.location_id.complete_name or line.location_id.display_name or ''"/>
                                        <t t-set="loc_short" t-value="loc_full.split('/', 2)[2] if loc_full.count('/') &gt;= 2 else loc_full"/>
                                        <tr>
                                            <td class="text-center">
                                                <span t-esc="global_seq"/>
                                                <t t-set="global_seq" t-value="global_seq + 1"/>
                                            </td>
                                            <td>
                                                <strong t-field="line.lot_id"/>
                                            </td>
                                            <td>
                                                <span t-esc="(lot and lot.x_bloque or '')"/>
                                            </td>
                                            <td class="text-center som-nowrap">
                                                <t t-set="grosor" t-value="lot and lot.x_grosor or ''"/>
                                                <span t-if="grosor and str(grosor).strip().replace('.','',1).replace('-','',1).isdigit()" t-esc="'%.2f' % float(grosor)"/>
                                                <span t-else="" t-esc="grosor or ''"/>
                                            </td>
                                            <td class="text-center som-nowrap">
                                                <t t-set="ancho" t-value="lot and lot.x_ancho or 0.0"/>
                                                <span t-if="ancho" t-esc="'%.3f' % float(ancho)"/>
                                            </td>
                                            <td class="text-center som-nowrap">
                                                <t t-set="alto" t-value="lot and lot.x_alto or 0.0"/>
                                                <span t-if="alto" t-esc="'%.3f' % float(alto)"/>
                                            </td>
                                            <td>
                                                <span t-esc="loc_short"/>
                                            </td>
                                            <td class="som-num" style="font-variant-numeric: tabular-nums;">
                                                <span t-field="line.area_sqm"/>
                                            </td>
                                            <td class="text-center"></td>
                                        </tr>
                                    </t>
                                </t>
                                <t t-if="not lines">
                                    <tr>
                                        <td colspan="9" class="text-center som-muted" style="padding: 12px; font-style: italic;">
                                            Esta orden no tiene placas registradas.
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="7" style="border-top: 2px solid #2f2f2f; font-weight: 800; text-transform: uppercase; letter-spacing: 0.3px;">
                                        Totales
                                    </td>
                                    <td class="som-num" style="border-top: 2px solid #2f2f2f; font-weight: 800; font-variant-numeric: tabular-nums;">
                                        <span t-esc="'%.4f' % sum(lines.mapped('area_sqm'))"/>
                                    </td>
                                    <td style="border-top: 2px solid #2f2f2f;"></td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- ================= NOTAS ================= -->
                        <div t-if="o.notes" style="border: 1px dashed #d8d8d8; padding: 10px; margin-top: 14px;">
                            <strong class="som-small som-muted som-upper">Notas:</strong>
                            <div style="font-size: 9px; white-space: pre-wrap; overflow-wrap: anywhere; word-break: break-word;" t-field="o.notes"/>
                        </div>

                        <!-- ================= FIRMAS ================= -->
                        <div class="som-avoid-break" style="margin-top: 50px; width: 100%;">
                            <div class="row" style="margin-top: 40px;">
                                <div class="col-1"></div>
                                <div class="col-4 text-center">
                                    <div style="border-top: 1px solid #000; padding-top: 5px;">
                                        <strong style="font-size: 9px; text-transform: uppercase;">Entrega (almacén)</strong>
                                        <div class="som-small som-muted" style="margin-top: 2px;">Nombre y firma</div>
                                    </div>
                                </div>
                                <div class="col-2"></div>
                                <div class="col-4 text-center">
                                    <div style="border-top: 1px solid #000; padding-top: 5px;">
                                        <strong style="font-size: 9px; text-transform: uppercase;">Recibe (taller)</strong>
                                        <div class="som-small som-muted" style="margin-top: 2px;">Nombre y firma</div>
                                    </div>
                                </div>
                                <div class="col-1"></div>
                            </div>
                        </div>

                        <p class="som-small som-muted" style="text-align: center; margin-top: 18px; letter-spacing: 0.3px;">
                            Documento de recolección interna · No es factura · No es comprobante fiscal
                        </p>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
