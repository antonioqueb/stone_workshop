<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_workshop_timer_pause_wizard_form" model="ir.ui.view">
        <field name="name">workshop.timer.pause.wizard.form</field>
        <field name="model">workshop.timer.pause.wizard</field>
        <field name="arch" type="xml">
            <form string="Pausar trabajo">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Se congelará el conteo de tiempo de esta orden. Puedes reanudarla cuando
                        vuelvas a trabajarla. El motivo es opcional.
                    </div>
                    <field name="order_id" invisible="1"/>
                    <group>
                        <field name="reason" placeholder="¿Por qué se pausa? (opcional)"/>
                        <field name="note" placeholder="Detalle adicional (opcional)"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm_pause" type="object" string="Pausar"
                            class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
